{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ForgeSwarm",
  "version": "0.1.0",
  "identifier": "com.openclaw.forgeswarm",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ForgeSwarm",
        "width": 1600,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
